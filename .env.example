# Database Driver: "sqlite" (default, zero-install) or "postgres"
DB_DRIVER=sqlite

# Database name (used as filename for SQLite: expense_tracker.db)
DB_NAME=expense_tracker

# PostgreSQL Configuration (only needed if DB_DRIVER=postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres

# Server Configuration
PORT=8080
